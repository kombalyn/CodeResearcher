# code-researcher configuration
# Copy this file to .env and fill in your values

# ── GitHub Token (optional, enables paid mode) ──────────────────────────────
# Without token: free mode, 60 GitHub requests/hour (shared per IP)
# With token:    paid mode, 5,000 GitHub requests/hour
#
# How to get a token:
#   1. Go to https://github.com/settings/tokens
#   2. Click "Generate new token (classic)"
#   3. Set expiration (e.g. 90 days or No expiration)
#   4. Check ONLY: public_repo (read-only access to public repos)
#   5. Click "Generate token" and copy the ghp_... string
#
GITHUB_TOKEN=

# ── Mode override (optional) ────────────────────────────────────────────────
# "free"  – force free mode even if GITHUB_TOKEN is set
# "paid"  – force paid mode (will fail if GITHUB_TOKEN is empty)
# Leave empty for auto-detection (paid if token present, free otherwise)
#
RESEARCHER_MODE=

# ── Result limits ────────────────────────────────────────────────────────────
# Max number of code files to return per search
# Default: 3 (free mode) or 10 (paid mode)
RESEARCHER_MAX_RESULTS=

# Max characters to include per file snippet
# Default: 1500
RESEARCHER_MAX_CHARS=1500

# HTTP request timeout in seconds
# Default: 10
RESEARCHER_TIMEOUT=10

# ── Source toggles ───────────────────────────────────────────────────────────
# GitHub Code Search (requires token for best results, works free with limits)
RESEARCHER_USE_GITHUB=true

# grep.app – always free, no token needed, good fallback
RESEARCHER_USE_GREP_APP=true

# StackOverflow – extract code from accepted answers (always free)
RESEARCHER_USE_SO=false
