# code-researcher configuration (Rust)
# Copy to .env and fill in your values

# GitHub Token (optional – enables paid mode, 5,000 req/h)
# Get one at: https://github.com/settings/tokens (public_repo scope only)
GITHUB_TOKEN=

# Mode: "free" | "paid" (auto-detected from token if not set)
RESEARCHER_MODE=

# Max results per search (default: 3 free / 10 paid)
RESEARCHER_MAX_RESULTS=

# Max characters per file snippet (default: 1500)
RESEARCHER_MAX_CHARS=1500

# Sources
RESEARCHER_USE_GITHUB=true
RESEARCHER_USE_GREP_APP=true
